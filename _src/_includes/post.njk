---
layout: base.njk
---

<article class="ma-article ma-flow">
  <div>
    <h1 class="ma-heading-1 ma-stack-8">{{ title }}</h1>
    <time datetime="{{ date | htmlDateString }}" class="ma-text-sm ma-text-subdued">{{ date | readableDate }}</time>
  </div>
  {{ content | safe }}
  {% if bskyPostUrl %}
    {% include "bluesky-interactions.html" %}
  {% endif %}
</article>
